# ─────────────────────────────────────────────────────────────────────────────
# SkillBridge — Environment Variables Template
# Salin file ini menjadi .env dan isi nilainya.
# JANGAN commit file .env ke git!
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase / PostgreSQL) ─────────────────────────────────────────
DB_URL=jdbc:postgresql://<host>:<port>/postgres
DB_USERNAME=postgres.<project-ref>
DB_PASSWORD=<your-db-password>

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gunakan string random minimal 64 karakter (256-bit)
# Generator: openssl rand -base64 64
JWT_SECRET=<your-very-long-random-secret-min-64-chars>
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Pisahkan beberapa origin dengan koma, tanpa spasi
# Contoh prod: https://skillbridge.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Spring Profile ────────────────────────────────────────────────────────────
# Pilihan: dev | test | prod
SPRING_PROFILES_ACTIVE=dev
